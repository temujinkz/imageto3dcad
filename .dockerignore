# Keep the image small and secret-free. The backend only needs app/*.py +
# requirements.txt; everything below is frontend, build output, or local state.
.git
.gitignore
node_modules
.next
out
.venv
storage
tests
public
components
lib
*.md
*.log
.DS_Store
**/__pycache__
**/*.pyc
package.json
package-lock.json
tsconfig.json
tsconfig.tsbuildinfo
next.config.ts
next-env.d.ts
postcss.config.js
tailwind.config.ts
eslint.config.mjs
.env
.env.local
.claude
.vercel
