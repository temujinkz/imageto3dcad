# Image-to-3D engine: "auto" tries cloud (Meshy -> Tripo -> fal) then the local
# offline silhouette engine. Force one with: meshy | tripo-api | fal-hunyuan3d |
# luma | csm | triposr | silhouette | mock.
IMAGE_TO_3D_PROVIDER=auto
USE_TRIPOSR=false
STORAGE_DIR=./storage/jobs
BACKEND_BASE_URL=http://localhost:8000
DEFAULT_THICKNESS_MM=5
DEFAULT_WIDTH_MM=80
DEFAULT_HEIGHT_MM=50
# "*" allows any origin (fine for local dev / hackathon use). For production,
# set an explicit comma-separated list, e.g. https://your-app.example.com
CORS_ORIGINS=*
ENABLE_REMBG=true
# "rembg" (default, lightweight) or "birefnet" (higher edge fidelity, needs
# `pip install -r requirements-birefnet.txt` and a GPU for reasonable speed)
BACKGROUND_REMOVAL_BACKEND=rembg

# Local TripoSR (optional)
PHOTO2CAD_TRIPOSR_RUN_PY=/absolute/path/to/TripoSR/run.py
PHOTO2CAD_TRIPOSR_PYTHON_BIN=python
PHOTO2CAD_TRIPOSR_EXTRA_ARGS=

# Cloud 3D reconstruction APIs (optional — enable one or more)
LUMA_API_KEY=
LUMA_API_BASE=https://api.lumalabs.ai/dream-machine/v1
CSM_API_KEY=
CSM_API_BASE=https://api.csm.ai/v1
TRIPO_API_KEY=
TRIPO_API_BASE=https://api.tripo3d.ai/v2
MESHY_API_KEY=
MESHY_API_BASE=https://api.meshy.ai/openapi/v1
# fal.ai hosted image-to-3D (optional, highest fidelity). FAL_MODEL defaults to
# Hunyuan3D-2; swap for fal-ai/trellis or fal-ai/triposr if preferred.
FAL_KEY=
FAL_MODEL=fal-ai/hunyuan3d/v2
# Gemini -> clean parametric STEP for AutoCAD (Track 1 CAD). Recommended.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ENABLE_GEMINI_CAD=true
RECONSTRUCTION_TIMEOUT_SECONDS=600
MAX_UPLOAD_IMAGES=20
MAX_VIDEO_FRAMES=12

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
